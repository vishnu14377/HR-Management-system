[
 {
  "doctype": "Custom Field",
  "name": "Employee-racedog_bench_section",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "racedog_bench_section",
  "fieldtype": "Section Break",
  "label": "Bench & Marketing",
  "insert_after": "employment_type"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-deployment_status",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "deployment_status",
  "fieldtype": "Select",
  "label": "Status",
  "options": "Working\nOn Bench\nMarketing",
  "default": "On Bench",
  "in_list_view": 1,
  "in_standard_filter": 1,
  "insert_after": "racedog_bench_section"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-hotlist",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "hotlist",
  "fieldtype": "Select",
  "label": "Hotlist",
  "options": "Red\nOrange\nGreen",
  "description": "Red = top priority (market now), Orange = has bandwidth / casual, Green = not looking. Auto-Green while Working.",
  "in_list_view": 1,
  "in_standard_filter": 1,
  "insert_after": "deployment_status"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-current_client",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "current_client",
  "fieldtype": "Link",
  "label": "Current Client",
  "options": "Client",
  "depends_on": "eval:doc.deployment_status=='Working'",
  "in_list_view": 1,
  "in_standard_filter": 1,
  "insert_after": "hotlist"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-bench_start_date",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "bench_start_date",
  "fieldtype": "Date",
  "label": "Bench Start Date",
  "insert_after": "current_client"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-availability_date",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "availability_date",
  "fieldtype": "Date",
  "label": "Available From",
  "in_standard_filter": 1,
  "insert_after": "bench_start_date"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-racedog_bench_col",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "racedog_bench_col",
  "fieldtype": "Column Break",
  "insert_after": "availability_date"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-marketing_owner",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "marketing_owner",
  "fieldtype": "Link",
  "label": "Marketing Owner",
  "options": "User",
  "in_standard_filter": 1,
  "insert_after": "racedog_bench_col"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-primary_skill",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "primary_skill",
  "fieldtype": "Link",
  "label": "Primary Skill",
  "options": "Skill",
  "in_standard_filter": 1,
  "insert_after": "marketing_owner"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-consultant_skills",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "consultant_skills",
  "fieldtype": "Table MultiSelect",
  "label": "Skills",
  "options": "RaceDog Skill Item",
  "insert_after": "primary_skill"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-visa_status",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "visa_status",
  "fieldtype": "Link",
  "label": "Work Authorization",
  "options": "Work Authorization",
  "in_standard_filter": 1,
  "insert_after": "consultant_skills"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-visa_expiry",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "visa_expiry",
  "fieldtype": "Date",
  "label": "Work Auth Expiry",
  "insert_after": "visa_status"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-racedog_docs_section",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "racedog_docs_section",
  "fieldtype": "Section Break",
  "label": "Documents",
  "insert_after": "visa_expiry"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-documents",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "documents",
  "fieldtype": "Table",
  "label": "Documents",
  "options": "Consultant Document",
  "description": "Resume, visa, DL, etc. Recruiters with access can download these.",
  "insert_after": "racedog_docs_section"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-racedog_rates_section",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "racedog_rates_section",
  "fieldtype": "Section Break",
  "label": "Billing (Manager Only)",
  "permlevel": 1,
  "insert_after": "documents"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-current_bill_rate",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "current_bill_rate",
  "fieldtype": "Currency",
  "label": "Bill Rate (client pays)",
  "permlevel": 1,
  "insert_after": "racedog_rates_section"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-current_pay_rate",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "current_pay_rate",
  "fieldtype": "Currency",
  "label": "Pay Rate (we pay)",
  "permlevel": 1,
  "insert_after": "current_bill_rate"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-racedog_rates_col",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "racedog_rates_col",
  "fieldtype": "Column Break",
  "permlevel": 1,
  "insert_after": "current_pay_rate"
 },
 {
  "doctype": "Custom Field",
  "name": "Employee-margin",
  "dt": "Employee",
  "module": "Racedog HR",
  "fieldname": "margin",
  "fieldtype": "Currency",
  "label": "Margin",
  "permlevel": 1,
  "read_only": 1,
  "description": "Auto-computed: Bill Rate minus Pay Rate.",
  "insert_after": "racedog_rates_col"
 }
]
